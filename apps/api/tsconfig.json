{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@workspace/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["src/**/*", "src/server.ts"],
  "exclude": ["node_modules", "dist"]
}
