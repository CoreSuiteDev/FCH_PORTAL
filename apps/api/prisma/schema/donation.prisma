
model Donation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

// Financial
  amount          Decimal @db.Decimal(12,2)
  currency        Currency @default(USD)
  status          PaymentStatus @default(PENDING)

// Payment Method
  paymentMethod    PaymentMethod @default(CARD)

  paymentIntentId String?        @unique
  paymentTransactionId String? @unique
  stripeChargeId String? @unique

  cardLast4        String?
  cardBrand        String?
  receiptUrl       String?
  invoiceUrl       String?

  failureReason String?
  
  refundedAmount Decimal @db.Decimal(12,2) @default(0)
  refundedAt DateTime?

  metadata Json?

  // Donor Preferences
  isAnonymous Boolean @default(false)
  message String? @db.Text

  

  // Relations
  donatorId String
  donator   Donator? @relation(fields: [donatorId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)


  @@index([status])
  @@index([currency])
  @@index([createdAt])
  @@index([donatorId])
  @@index([userId])
  @@index([status, createdAt])
  @@index([donatorId, createdAt])

  @@map("donations")
}

model Donator {
  id String @id @default(cuid())

  name  String @db.VarChar(120)
  email String? @db.VarChar(255)
  phone String? @db.VarChar(20)

  stripeCustomerId String? @unique

  totalDonationAmount Decimal @db.Decimal(12,2) @default(0)
  totalDonationCount Int @default(0)

  donations Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([email])
  @@index([email])
  @@index([stripeCustomerId])

  @@map("donators")
}
