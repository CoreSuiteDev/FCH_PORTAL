model Donation {
    id String @id @default(cuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    amount Float
    currency Currency
    status PaymentStatus
    paymentIntentId String @unique

    stripeCustomerId String?
    paymentMethod String?
    cardLast4 String?
    cardBrand String?
    receiptUrl String?
    errorMessage String?


    donatorId String
    donator Donator? @relation(fields: [donatorId], references: [id], onDelete: Cascade)

    userId String?
    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
    

    @@index([donatorId])
    @@index([userId])
    @@index([status])
    @@index([createdAt])
}

model Donator {
    id String @id @default(cuid())
    
    name String
    email String
    phone String?
    
    donations Donation[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([email])
    @@unique([email])
    
}


model SponsorShip {
    id String @id @default(cuid())
    createdAt DateTime @default(now())
    updateAt DateTime @updatedAt

    amount Float
    currency Currency
    status PaymentStatus

    paymentIntentId String @unique
    stripeCustomerId String?
    paymentMethod String?
    cardLast4 String?
    cardBrand String?
    receiptUrl String?
    errorMessage String?

    sponsorId String
    sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)


    @@index([sponsorId])
    @@index([userId])
    @@index([status])
    @@index([createdAt])
}

model Sponsor {
    id String @id @default(cuid())

    name String
    email String
    phone String?
    
    sponsorShips SponsorShip[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    
    @@index([email])
}