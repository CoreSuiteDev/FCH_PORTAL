model SponsorPlan {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  name String @db.VarChar(100)
  slug String @unique

  tier Tier

  amount   Decimal  @db.Decimal(12,2)
  currency Currency @default(USD)

  description String? @db.Text
  benefits    Json?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  sortOrder Int @default(0)

  sponsorships Sponsorship[]

  @@index([tier])
  @@index([isActive])
  @@index([sortOrder])

  @@map("sponsor_plans")
}

model Sponsorship {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Selected Plan
  planId String
  plan   SponsorPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  // Snapshot of pricing (history preserved)
  amount   Decimal  @db.Decimal(12,2)
  currency Currency @default(USD)

  status PaymentStatus @default(PENDING)

  paymentMethod PaymentMethod?

  paymentIntentId      String? @unique
  paymentTransactionId String? @unique
  stripeChargeId       String? @unique
  stripeCustomerId     String?

  cardBrand String?
  cardLast4 String?

  receiptUrl String?
  invoiceUrl String?

  errorMessage String?

  refundedAmount Decimal @db.Decimal(12,2) @default(0)
  refundedAt DateTime?

  metadata Json?

  startsAt DateTime?
  expiresAt DateTime?

  sponsorId String
  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  userId String?
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([sponsorId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([sponsorId, createdAt])

  @@map("sponsorships")
}

model Sponsor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  name  String @db.VarChar(120)
  email String @unique
  phone String? @db.VarChar(20)

  company String?
  website String?
  logo    String?

  sponsorships Sponsorship[]

  @@index([email])

  @@map("sponsors")
}