model ContactInquery {
  id String @id @default(cuid())

  name    String
  email   String
  message String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@map("contact_inqueries")
}

model NewsletterSubscriber {
  id String @id @default(cuid())

  name String
  email String @unique

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("newsletter_subscribers")
}