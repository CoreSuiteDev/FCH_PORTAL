model SupportTicket {
  id String @id @default(cuid())

  userId    String
  subject   String
  message   String
  status    TicketStatus @default(PENDING)
  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("support_tickets")
}
