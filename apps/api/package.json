{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "start": "bun src/server.ts",
    "db:seed": "bun --env-file=../../.env prisma/seed.ts",
    "db:studio": "bun --env-file=../../.env x prisma studio",
    "db:push": "bun --env-file=../../.env x prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@trpc/server": "^11.17.0",
    "@workspace/types": "workspace:*",
    "better-auth": "^1.6.14",
    "bullmq": "^5.79.3",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "moment-timezone": "^0.6.2",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "stripe": "^22.3.0",
    "trpc-to-openapi": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prisma": "^7.8.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
}
